# ─── Bot ───────────────────────────────────────────────────────────────
BOT_TOKEN=7123456789:AAFxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
WEBHOOK_SECRET=change_this_to_a_random_32char_secret
WEBHOOK_HOST=https://your-primary-domain.com        # Railway URL
WEBHOOK_PATH=/webhook

# ─── Owner (your Telegram user_id) ────────────────────────────────────
OWNER_ID=123456789

# ─── Database ──────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://user:password@host:5432/myqrro

# ─── Redis (optional — falls back to in-memory if not set) ────────────
REDIS_URL=redis://localhost:6379/0

# ─── App config ────────────────────────────────────────────────────────
ENVIRONMENT=production                  # production | development
LOG_LEVEL=INFO
MAX_HISTORY_PER_USER=50
RATE_LIMIT_PER_MINUTE=10
RATE_LIMIT_PER_DAY=200
DEFAULT_WATERMARK_TEXT=@myqrro_bot
WATERMARK_ENABLED=true

# ─── Failover (Render backup URL) ──────────────────────────────────────
BACKUP_URL=https://your-backup-domain.onrender.com

# ─── Cloudflare Worker ─────────────────────────────────────────────────
# Set these in Cloudflare Worker environment variables (not here)
# CF_PRIMARY_URL=https://your-railway-app.railway.app
# CF_BACKUP_URL=https://your-app.onrender.com
# CF_WEBHOOK_SECRET=same_as_WEBHOOK_SECRET
